# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=ncp_wheels
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis and Celery
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# EasyPaisa Configuration
EASYPAISA_MERCHANT_ID=your-merchant-id
EASYPAISA_MERCHANT_KEY=your-merchant-key
EASYPAISA_SANDBOX=True

# JazzCash Configuration
JAZZCASH_MERCHANT_ID=your-merchant-id
JAZZCASH_PASSWORD=your-password
JAZZCASH_INTEGRITY_SALT=your-integrity-salt
JAZZCASH_SANDBOX=True

# UBL Configuration
UBL_MERCHANT_ID=your-merchant-id
UBL_API_KEY=your-api-key
UBL_API_SECRET=your-api-secret
UBL_SANDBOX=True
